[Unit]
Description=Bittrees Cloudflared Tunnel For IPFS
After=network-online.target ipfs-api-proxy.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__ROOT_DIR__
EnvironmentFile=__ROOT_DIR__/.env
ExecStart=/usr/bin/env npm run tunnel:start
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
